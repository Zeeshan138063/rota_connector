# ─────────────────────────────────────────────────────────────────────────────
# ROTA Connector SDK - Environment Configuration Template
# 
# Copy this file to '.env' in your project root and fill in the values below.
# These credentials are used by the 'rota_service.py' integration template.
# ─────────────────────────────────────────────────────────────────────────────

# The Base URL of the ROTA Core Service.
# Leave blank or remove to default to the production URL: https://rota-backend.31g.co.uk
ROTA_BASE_URL=http://localhost:8000

# Your unique Project Client ID (provided when you register a project in ROTA Core)
ROTA_CLIENT_ID=your_project_client_id_here

# Your secret key for authenticating as this project. Keep this secure!
ROTA_CLIENT_SECRET=your_project_client_secret_here
